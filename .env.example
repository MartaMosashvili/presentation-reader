# TTS პროვაიდერი: azure (ნატიური ქართული ხმები) ან openai
TTS_PROVIDER=azure

# Azure Speech (portal.azure.com -> Speech service -> Keys and Endpoint)
AZURE_SPEECH_KEY=your-azure-key
AZURE_SPEECH_REGION=westeurope
AZURE_VOICE=ka-GE-EkaNeural

# OpenAI (სათადარიგო ვარიანტი)
OPENAI_API_KEY=sk-your-key
